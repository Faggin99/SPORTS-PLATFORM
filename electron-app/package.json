{
  "name": "tactiplan-desktop",
  "version": "2.0.0",
  "description": "TactiPlan - Gestao de Treinos",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "keywords": ["sports", "training", "tactical", "tactiplan"],
  "author": "TactiPlan",
  "license": "MIT",
  "build": {
    "appId": "com.tactiplan.app",
    "productName": "TactiPlan",
    "directories": {
      "output": "build-output"
    },
    "files": [
      "main.js",
      "assets/**/*",
      "!assets/icon.ico.bak"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TactiPlan",
      "artifactName": "TactiPlan-Setup-${version}.exe",
      "differentialPackage": false,
      "perMachine": false
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "assets/icon.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TactiPlan"
    }
  },
  "devDependencies": {
    "electron": "^39.2.1",
    "electron-builder": "^26.0.12"
  }
}
